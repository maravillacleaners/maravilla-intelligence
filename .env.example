# Maravilla Intelligence System - Environment Variables Template
# Copy to .env and fill in actual values (NEVER commit .env with secrets)

# Node Environment
NODE_ENV=development

# Industry Classification (SWAPPABLE)
PRIMARY_NAICS=561720

# Airtable Integration
AIRTABLE_API_KEY=patXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXXXXXXXX

# n8n Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/maravilla-intelligence

# Claude API Integration
CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# System Configuration
SYSTEM_NAME=Maravilla Intelligence
LOG_LEVEL=info

# Hunter.io Email Enrichment API
# Register free at: https://hunter.io (100 req/month free plan)
# Used by /api/enrich to find business emails and contact patterns
HUNTER_API_KEY=your-hunter-io-api-key

# Google Places API for location verification
# https://developers.google.com/maps/documentation/places
GOOGLE_PLACES_API_KEY=your-google-places-api-key
